PORT=3000
# N8N webhook URL for incoming message replies (set after n8n workflow is created)
WEBHOOK_URL=https://your-n8n-app.onrender.com/webhook/whatsapp-reply

# Google service account JSON (paste the full JSON from GCP console, or base64 encode it)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@project.iam.gserviceaccount.com"}

# N8N webhook URL for daily scrape results
SCRAPE_N8N_URL=https://your-n8n-app.onrender.com/webhook/scrape-results

# Scrape schedule (Lagos time)
SCRAPE_HOUR=8
SCRAPE_MINUTE=45
